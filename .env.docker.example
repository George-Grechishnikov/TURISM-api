# Скопируйте в .env рядом с docker-compose.yml (опционально)

WEB_PORT=8080

POSTGRES_DB=turizm
POSTGRES_USER=turizm
POSTGRES_PASSWORD=turizm

# Секрет JWT (если пусто — используется DJANGO_SECRET_KEY для совместимости с .env)
JWT_SECRET=

DJANGO_SECRET_KEY=change-me-in-production

# Origin браузера при открытии http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Сборка фронта (build-arg для образа web). Без ключа карта и маршрут по дорогам (multiRouter) не работают.
# После смены ключа: docker compose build web --no-cache
# В кабинете https://developer.tech.yandex.ru — сервис «JavaScript API и HTTP Геокодер»;
# в HTTP Referrer добавьте каждый origin, с которого открываете сайт (со слэшем и * в конце), например:
#   http://localhost:8080/*
#   http://127.0.0.1:8080/*
#   http://100.78.89.35:8080/*   ← Tailscale / LAN, если вкладка именно такая
VITE_YANDEX_MAPS_API_KEY=

# По умолчанию в compose уже зеркало Яндекса. Для официального PyPI:
# PIP_INDEX_URL=https://pypi.org/simple

# Опционально LLM
YANDEX_CLOUD_FOLDER_ID=
YANDEX_IAM_TOKEN=

