VITE_API_BASE=
# Один ключ: JavaScript API + HTTP Геокодер + маршрутизация на карте (multiRouter).
# https://developer.tech.yandex.ru/services/ — без ключа линия по дорогам и геокод адреса не работают.
# В кабинете ключа в Referrer укажите origin вкладки, например http://100.78.89.35:8080/* (Tailscale/LAN).
# Скопируйте в .env (не коммитьте .env)
VITE_YANDEX_MAPS_API_KEY=

