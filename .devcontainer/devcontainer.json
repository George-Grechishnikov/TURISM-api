{
  "name": "Turizm API (Go + Node + Postgres)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "go.goroot": "/usr/local/go",
        "go.gopath": "/go"
      }
    }
  },
  "forwardPorts": [5173, 8000, 5432],
  "portsAttributes": {
    "5173": { "label": "Vite", "onAutoForward": "notify" },
    "8000": { "label": "Go API" },
    "5432": { "label": "PostgreSQL" }
  },
  "postCreateCommand": "bash -lc 'cd frontend && npm ci && cd ../server && go mod download'"
}
